# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Security
SECRET_KEY=generate_a_secure_random_string_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption key for MT5 passwords (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# App
APP_NAME=PesaPips Trading AI
DEBUG=False

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PesaPips <noreply@pesapips.com>

# Market Data
TWELVE_DATA_KEY=

# CORS — allowed frontend origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173

# MT5 Bridge Path (optional, overrides default)
MT5_BRIDGE_PATH=

# Telegram Bot (for trade alerts, regime changes, daily summaries)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Flutterwave / M-Pesa (for instant payment verification)
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
